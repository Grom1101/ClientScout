POSTGRES_USER=clientscout
POSTGRES_PASSWORD=replace-with-a-local-dev-password
POSTGRES_DB=clientscout

ConnectionStrings__DefaultConnection=Host=localhost;Database=clientscout;Username=clientscout;Password=replace-with-a-local-dev-password
Jwt__Secret=replace-with-a-random-32-byte-minimum-secret
Jwt__Issuer=clientscout.app
Jwt__Audience=clientscout.tma

Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=https://localhost:5173

Admin__AccountIds__0=replace-with-admin-account-guid
Admin__TelegramUserIds__0=replace-with-admin-telegram-id

Telegram__BotToken=replace-with-telegram-bot-token
Telegram__ApiId=replace-with-telegram-api-id
Telegram__ApiHash=replace-with-telegram-api-hash

GROQ_API_KEY=replace-with-groq-key
OPENROUTER_API_KEY=replace-with-openrouter-key
GEMINI_API_KEY=replace-with-gemini-key
BLUESMINDS_API_KEY=replace-with-bluesminds-key
